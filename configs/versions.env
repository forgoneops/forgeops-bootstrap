# configs/versions.env
#
# Single source of truth for every pinned component version.
# update.sh reads this file and never moves a component past what's declared
# here — bumping a version is a deliberate, reviewed edit to this file.
#
# Format: SIMPLE_KEY=value (sourced as a shell file — no spaces around '=').

# --- Docker -----------------------------------------------------------------
DOCKER_APT_CHANNEL="stable"          # Docker's official apt repo channel
DOCKER_COMPOSE_PLUGIN_MIN="2.27"     # minimum acceptable docker compose plugin version

# --- Node.js ------------------------------------------------------------------
NODE_MAJOR="22"                      # Node.js LTS line, pinned via NodeSource setup script

# --- Container images (pinned to major.minor, not `latest`) -----------------
CADDY_IMAGE="caddy:2.8-alpine"
PORTAINER_IMAGE="portainer/portainer-ce:2.39.5-alpine"
POSTGRES_IMAGE="postgres:16.4-alpine"
REDIS_IMAGE="redis:7.4-alpine"
UPTIME_KUMA_IMAGE="louislam/uptime-kuma:1.23.16"
WATCHTOWER_IMAGE="containrrr/watchtower:1.7.1"

# --- Python tooling -----------------------------------------------------------
UV_VERSION="0.4.29"                  # pinned uv release installed by install.sh

# --- VPN-gated MCP engine (Layer 6/7/5 platform vision — see PROJECT_SPEC.md) ---
# Images pulled as-is from a registry, pinned to a specific tag (never `:latest`,
# matching the policy above).
WGEASY_IMAGE="ghcr.io/wg-easy/wg-easy:15.3.0"
CADVISOR_IMAGE="gcr.io/cadvisor/cadvisor:v0.60.5"
PROMETHEUS_IMAGE="prom/prometheus:v3.13.1"
GRAFANA_IMAGE="grafana/grafana:13.1.0"
POSTGRES_MCP_IMAGE="crystaldba/postgres-mcp:0.3.0"

# --- MCP stdio-bridge (docker/mcp-stdio-bridge/Dockerfile) -------------------
# Every build-time input the bridge's Dockerfile actually consumes, pinned
# here. Replaces the old MCP_PROXY_IMAGE entry above (removed): that was
# passed to docker-compose.yml as a build-arg, but the Dockerfile never
# declared or used an arg by that name, so it was a dead pin — the image tag
# it named was never pulled or referenced anywhere. mcp-proxy is installed
# via pip inside the bridge image, not run as its own container, so it was
# never really "an image" to pin in the first place.
PYTHON_BASE_IMAGE="python:3.12-slim"       # bridge's base image — same value the Dockerfile floated on by default before this pin existed
MCP_PROXY_VERSION="0.12.0"                 # pip version of `mcp-proxy` (PyPI) — verified against pypi.org/pypi/mcp-proxy/json this session, matches the version number the old (unused) MCP_PROXY_IMAGE tag already named
MCP_FILESYSTEM_SERVER_VERSION="2026.7.10"  # npm version of @modelcontextprotocol/server-filesystem — verified against registry.npmjs.org this session
# @modelcontextprotocol/server-git (the package docker-compose.yml's mcp-git
# service asks npx to run) returned 404 from registry.npmjs.org this
# session — that npm package does not appear to exist. The official git MCP
# server actually ships as the PyPI/uvx package `mcp-server-git`, not npm,
# so mcp-git was already broken before this pinning fix (npx can never
# resolve a package that isn't published). Left UNPINNED (blank) rather
# than inventing a version number for a package that doesn't exist —
# docker/mcp-stdio-bridge/Dockerfile falls back to npx's own (already
# broken) floating resolution when this is blank. mcp-git needs a real npm
# package name or a uvx-based bridge variant before it will run at all;
# see docker/mcp-stdio-bridge/Dockerfile's "KNOWN BROKEN" comment and
# SECURITY.md's "Known gaps" section.
MCP_GIT_SERVER_VERSION=""

# Mem0 (server + its MCP wrapper) ship no maintained, versioned Docker image
# upstream — mem0ai/mem0's own docker-compose builds the server from its own
# Dockerfile, and coleam00/mcp-mem0 only ever published a Dockerfile, not a
# registry image. Both are therefore built from source at install time
# (step_install_mem0), pinned by *git ref*, not an image tag. This is the one
# exception to "no floating references" in this file — it's already a floating
# git ref rather than a resolvable version tag, and MUST be pinned to an actual
# release/commit before this is used beyond a single maintainer's own VPN.
# See docs/MEMORY.md "Pinning Mem0" for how to tighten this.
MEM0_GIT_REF="main"                  # UNPINNED — verify github.com/mem0ai/mem0/releases and replace before relying on this long-term
MEM0_MCP_GIT_REF="main"              # UNPINNED — coleam00/mcp-mem0 has had no commits in 14+ months; verify it still builds before relying on it
