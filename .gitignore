# Secrets — never commit
.env
*.env.local

# Runtime state and logs
logs/
backups/
!backups/.gitkeep
!logs/.gitkeep

# Generated Caddy config (rendered by scripts/render_caddyfile.sh)
docker/Caddyfile

# Mem0 source checkouts (step_install_mem0 clones these at install time,
# pinned by MEM0_GIT_REF/MEM0_MCP_GIT_REF in configs/versions.env — not
# vendored into this repo)
build/

# Migration artifacts pulled from a source host for manual review
docker-compose.yml.from-source

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
.ruff_cache/
.mypy_cache/
