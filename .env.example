# .env.example
#
# Template for the runtime secrets/config consumed by docker-compose.yml and
# the ForgeOps scripts. Copy is made automatically by install.sh on first run
# (as .env, git-ignored, mode 600) with every CHANGEME_* value replaced by a
# random secret. Never commit a real .env file.

# --- Project ------------------------------------------------------------------
PROJECTS_DIR=/opt/forgeops/projects
TIMEZONE=UTC

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=forgeops
POSTGRES_PASSWORD=CHANGEME_POSTGRES_PASSWORD
POSTGRES_DB=forgeops

# --- Redis ------------------------------------------------------------------
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD

# --- Portainer --------------------------------------------------------------
# Set to "true" to give Portainer a public Caddy route (portainer.<DOMAIN>).
EXPOSE_PORTAINER=false

# --- Uptime Kuma --------------------------------------------------------------
# Set to "true" to give Uptime Kuma a public Caddy route (status.<DOMAIN>).
EXPOSE_UPTIME_KUMA=false

# --- Caddy / domain -----------------------------------------------------------
# Base domain used for auto-HTTPS site blocks when a service is exposed above.
# Leave blank to keep Caddy on plain HTTP for a bare-IP / no-domain install.
DOMAIN=

# --- Backups ------------------------------------------------------------------
BACKUP_RETENTION_DAYS=14

# --- VPN-gated MCP engine (WireGuard + observability + memory + MCP gateway) --
# Everything below is reachable ONLY via the WireGuard VPN + a bearer token —
# see SECURITY.md "VPN-gated MCP engine" and docs/VPN_SETUP.md. There is no
# EXPOSE_MCP flag: publishing MCP to the public internet is out of scope for
# this repo and would need its own threat-reviewed change.

# Public IP or DNS name of this VPS — baked into every WireGuard peer config
# so a client knows where to connect. Required before adding a peer.
WG_HOST=CHANGEME_WG_HOST
# UDP port WireGuard listens on. This is the one new host-facing port opened
# by this feature set (see step_install_wireguard's WG allow rule).
WG_PORT=51820
# wg-easy's own admin UI password (peer add/remove/QR-code). Never exposed
# publicly — reachable only through the VPN it manages, same trust chain as
# everything else behind it.
WG_PASSWORD=CHANGEME_WG_PASSWORD

# Bearer token every MCP client must send (Authorization: Bearer <token>).
# Required even from inside the VPN — defense in depth against a compromised
# VPN peer. Rotate via docs/MCP_GATEWAY.md's one-command rotation procedure.
MCP_BEARER_TOKEN=CHANGEME_MCP_BEARER_TOKEN

# Dedicated least-privilege Postgres role for Mem0 (its own schema, not the
# stack's superuser). Created by step_install_mem0.
MEM0_DB_PASSWORD=CHANGEME_MEM0_DB_PASSWORD
# Local, no-cloud-dependency embedding provider (see PROJECT_SPEC.md's
# "No cloud dependency" principle) — swap to an API-key-based provider here
# if you'd rather trade that principle for embedding quality.
MEM0_EMBEDDER_PROVIDER=fastembed
# Single-maintainer memory namespace — every device/client shares this one
# user_id on purpose (see docs/MEMORY.md).
MEM0_USER_ID=maintainer

# Dedicated least-privilege, READ-ONLY Postgres role for the postgres-mcp
# bridge — it must never be able to write to the database (see SECURITY.md).
POSTGRES_MCP_RO_PASSWORD=CHANGEME_POSTGRES_MCP_RO_PASSWORD

# Set to "true" to also give Grafana a public Caddy route (grafana.<DOMAIN>),
# same opt-in pattern as EXPOSE_PORTAINER/EXPOSE_UPTIME_KUMA — flip it and
# re-run install.sh/update.sh to regenerate docker/Caddyfile. Leave false —
# the VPN is the intended access path; this flag is not part of the
# documented workflow in docs/VPN_SETUP.md.
EXPOSE_GRAFANA=false
